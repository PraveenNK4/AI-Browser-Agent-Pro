# =============================================================================
# OLLAMA ONLY - LLM SETTINGS
# =============================================================================

# Set default LLM (fixed to Ollama only)
DEFAULT_LLM=ollama

# Set the Ollama model to use
LLM_MODEL_NAME=qwen2.5:14b
SCRIPT_GEN_MODEL=qwen2.5-coder:7b
SCRIPT_GEN_PROVIDER=ollama

# Planner model (used for task planning) - Provider must be set for planner to be used
PLANNER_LLM_PROVIDER=ollama
PLANNER_LLM_MODEL_NAME=qwen2.5:7b
PLANNER_LLM_TEMPERATURE=0.3

# Extraction model (used for data extraction)
EXTRACTION_LLM_PROVIDER=ollama
EXTRACTION_LLM_MODEL_NAME=qwen2.5:7b
EXTRACTION_LLM_TEMPERATURE=0.3

# Ollama server settings
OLLAMA_ENDPOINT=http://localhost:11434

# =============================================================================
# BROWSER SETTINGS (Previously in Browser Settings tab)
# =============================================================================

# Set to false to disable anonymized telemetry
ANONYMIZED_TELEMETRY=false

# LogLevel: Set to debug to enable verbose logging, set to result to get results only. Available: result | debug | info
BROWSER_USE_LOGGING_LEVEL=info

# Browser executable path (set to Chrome for automation)
BROWSER_PATH="C:\Program Files\Google\Chrome\Application\chrome.exe"

# Browser user data directory (leave empty for default)
BROWSER_USER_DATA=

# Browser debugging settings
BROWSER_DEBUGGING_PORT=9222
BROWSER_DEBUGGING_HOST=localhost

# Browser behavior settings
# Set to false to close browser between tasks (prevents state confusion)
KEEP_BROWSER_OPEN=false
USE_OWN_BROWSER=false
HEADLESS=true
DISABLE_SECURITY=false


# =============================================================================
# AGENT CONFIGURATION (Previously in Agent Settings tab)
# =============================================================================

# Agent behavior settings (increased for complex tasks like SauceDemo)
MAX_STEPS=35
MAX_ACTIONS=3
MAX_INPUT_TOKENS=128000

# Tool calling method (auto/json_mode/function_calling/tools)
TOOL_CALLING_METHOD=auto

# Vision settings (set to false for local models to save resources)
USE_VISION=false

# Memory settings (completely disable to prevent task confusion)
ENABLE_MEMORY=false

# LLM temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.7

# Context length for Ollama models
OLLAMA_NUM_CTX=16000

# =============================================================================
# FILE PATHS (Previously in Browser Settings tab)
# =============================================================================

# Save directories
AGENT_HISTORY_PATH=./tmp/agent_history
DOWNLOADS_PATH=./tmp/downloads
RECORDING_PATH=./tmp/record_videos
TRACE_PATH=./tmp/traces

# =============================================================================
# DISPLAY SETTINGS
# =============================================================================

# Format: WIDTHxHEIGHTxDEPTH
RESOLUTION=1920x1080x24
# Width in pixels
RESOLUTION_WIDTH=1920
# Height in pixels
RESOLUTION_HEIGHT=1080